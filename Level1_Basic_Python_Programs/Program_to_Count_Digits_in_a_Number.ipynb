      "source": [
        "num = int(input(\"Enter a number: \"))\n",
        "count = 0\n",
        "\n",
        "while num != 0:\n",
        "    num = num // 10\n",
        "    count += 1\n",
        "\n",
        "print(\"Number of digits:\", count)"
      ],
