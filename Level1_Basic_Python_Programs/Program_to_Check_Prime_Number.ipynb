      "source": [
        "num = int(input(\"Enter a number: \"))\n",
        "flag = True\n",
        "\n",
        "if num > 1:\n",
        "    for i in range(2, num):\n",
        "        if num % i == 0:\n",
        "            flag = False\n",
        "            break\n",
        "\n",
        "if flag:\n",
        "    print(\"Prime number\")\n",
        "else:\n",
        "    print(\"Not a prime number\")"
      ],
