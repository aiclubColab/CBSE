      "source": [
        "# Area_and_Perimeter_of_a_Rectangle\n",
        "\n",
        "length = float(input(\"Enter length: \"))\n",
        "breadth = float(input(\"Enter breadth: \"))\n",
        "\n",
        "area = length * breadth\n",
        "perimeter = 2 * (length + breadth)\n",
        "\n",
        "print(\"Area of rectangle =\", area)\n",
        "print(\"Perimeter of rectangle =\", perimeter)"
      ]
