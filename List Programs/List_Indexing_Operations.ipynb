      "source": [
        "# List_Indexing_Operations\n",
        "\n",
        "num = [23, 12, 5, 9, 65, 44]\n",
        "\n",
        "# Length of list\n",
        "print(\"Length of list:\", len(num))\n",
        "\n",
        "# Positive indexing (2nd to 4th)\n",
        "print(\"Elements from 2nd to 4th:\", num[1:4])\n",
        "\n",
        "# Negative indexing (3rd to 5th)\n",
        "print(\"Elements using negative indexing:\", num[-4:-1])"
      ]
    }
  ]
